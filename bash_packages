#!/bin/bash
# ==============================================================================
# PACKAGE LIST MANAGEMENT
# ==============================================================================
# Curated package lists for auditing and bootstrapping machines across distros.
#
# Lists live in packages/*.json — one file per category. Each entry maps a
# logical name to per-installer package names. Use null for installers where
# the package is unavailable.
#
#   packages/core.json:
#     {
#       "netcat": { "pacman": "openbsd-netcat", "apt": "netcat-openbsd",
#                   "dnf": "nmap-ncat" },
#       "atuin":  { "pacman": "atuin", "apt": null, "dnf": null,
#                   "_note": "Install via setup.atuin.sh on apt/dnf" }
#     }
#
# Supported installer keys: pacman, apt, dnf, aur, flatpak.
# Per-entry resolution picks the first applicable installer in this priority:
#   native (pacman/apt/dnf) > aur (only on pacman+helper) > flatpak (if installed)
#
# Files named system-<spec>.json only load when BASH_SPECIALISATION matches.
#
# Commands:
#   pkg_check [category...]   - Show packages from lists that are not installed
#   pkg_install [category...] - Install missing packages from lists
# ==============================================================================

_pkg_list_dir() { echo "$BASH_CONFIG_DIR/packages"; }

# ------------------------------------------------------------------------------
# Manager detection and per-installer operations
# ------------------------------------------------------------------------------
_pkg_native_manager() {
    case "$(_detect_os 2>/dev/null)" in
        arch)            echo "pacman" ;;
        debian|raspbian) echo "apt" ;;
        rhel)            echo "dnf" ;;
        *)               echo "" ;;
    esac
}

_pkg_installed_pacman()  { pacman -Qqe 2>/dev/null; }
_pkg_installed_apt()     { dpkg-query -W -f='${Package}\n' 2>/dev/null; }
_pkg_installed_dnf()     { rpm -qa --qf '%{NAME}\n' 2>/dev/null; }
_pkg_installed_flatpak() { flatpak list --app --columns=application 2>/dev/null; }
_pkg_installed_aur() {
    local helper; helper=$(_detect_aur_helper 2>/dev/null)
    [[ -n "$helper" ]] && "$helper" -Qqm 2>/dev/null
}

_pkg_install_pacman()  { sudo pacman -S --needed "$@"; }
_pkg_install_apt()     { sudo apt-get install -y "$@"; }
_pkg_install_dnf()     { sudo dnf install -y "$@"; }
_pkg_install_flatpak() { flatpak install -y "$@"; }
_pkg_install_aur() {
    local helper; helper=$(_detect_aur_helper 2>/dev/null)
    if [[ -z "$helper" ]]; then
        echo -e "${BC_COLOR_RED}  ✗ No AUR helper found (yay/paru)${BC_COLOR_RESET}"
        return 1
    fi
    "$helper" -S --needed "$@"
}

# Installer priority list for this machine, one name per line.
_pkg_priority() {
    local native; native=$(_pkg_native_manager)
    [[ -n "$native" ]] && echo "$native"
    [[ "$native" == "pacman" ]] && [[ -n "$(_detect_aur_helper 2>/dev/null)" ]] && echo "aur"
    command -v flatpak &>/dev/null && echo "flatpak"
}

# ------------------------------------------------------------------------------
# JSON list discovery and resolution
# ------------------------------------------------------------------------------

# Specialisation gating by filename.
_pkg_spec_allows() {
    local base; base=$(basename "$1" .json)
    case "$base" in
        system-*) [[ "${base#system-}" == "${BASH_SPECIALISATION:-}" ]] ;;
        *)        return 0 ;;
    esac
}

# Print every packages/*.json that passes specialisation gating.
_pkg_active_files() {
    local dir; dir=$(_pkg_list_dir)
    [[ -d "$dir" ]] || return
    local f
    for f in "$dir"/*.json; do
        [[ -f "$f" ]] || continue
        _pkg_spec_allows "$f" && echo "$f"
    done
}

# Resolve a category name (e.g. "core") to its JSON file, or empty.
_pkg_category_file() {
    local file="$(_pkg_list_dir)/$1.json"
    [[ -f "$file" ]] && _pkg_spec_allows "$file" && echo "$file"
}

# For a JSON file, emit "installer<TAB>logical<TAB>pkgname" for every entry,
# choosing the first applicable installer per entry from _pkg_priority.
# Entries with no applicable installer are skipped.
_pkg_resolve_file() {
    local file="$1"
    local pri_json
    pri_json=$(_pkg_priority | jq -R . | jq -s .)
    [[ "$pri_json" == "[]" ]] && return

    jq -r --argjson pri "$pri_json" '
        to_entries[] as $e
        | ($pri | map(select($e.value[.] != null)) | first) as $i
        | if $i then "\($i)\t\($e.key)\t\($e.value[$i])" else empty end
    ' "$file"
}

# ------------------------------------------------------------------------------
# Public commands
# ------------------------------------------------------------------------------

_pkg_require_jq() {
    if ! command -v jq &>/dev/null; then
        echo -e "${BC_COLOR_RED}  ✗ jq is required — install it first (see packages/core.json).${BC_COLOR_RESET}"
        return 1
    fi
}

pkg_check() {
    _pkg_require_jq || return 1
    local -a args=("$@")
    local any_missing=0

    local width; width=$(tput cols 2>/dev/null || echo 80)
    [[ $width -gt 100 ]] && width=100
    local line; line=$(printf '─%.0s' $(seq 1 "$width"))
    echo -e "\n${BC_COLOR_BOLD}${BC_COLOR_CYAN}  Package Audit${BC_COLOR_RESET}"
    echo -e "${BC_COLOR_CYAN}${line}${BC_COLOR_RESET}"

    local native; native=$(_pkg_native_manager)
    if [[ -z "$native" ]]; then
        echo -e "${BC_COLOR_YELLOW}  ⚠ No supported native package manager detected.${BC_COLOR_RESET}"
        return 1
    fi
    echo -e "  Native manager: ${BC_COLOR_BOLD}$native${BC_COLOR_RESET}${BASH_SPECIALISATION:+  (spec: $BASH_SPECIALISATION)}"

    # Cache the installed set per installer.
    declare -A installed_file=()
    local cleanup=""
    _get_installed_file() {
        local mgr="$1"
        if [[ -z "${installed_file[$mgr]:-}" ]]; then
            local tmp; tmp=$(mktemp)
            cleanup="$cleanup $tmp"
            "_pkg_installed_$mgr" > "$tmp" 2>/dev/null
            installed_file[$mgr]="$tmp"
        fi
        echo "${installed_file[$mgr]}"
    }

    _check_one_file() {
        local file="$1"
        local label; label=$(basename "$file" .json)
        local resolved; resolved=$(_pkg_resolve_file "$file")
        if [[ -z "$resolved" ]]; then
            echo -e "${BC_COLOR_BLUE}  ◦ $label — nothing applies on this system${BC_COLOR_RESET}"
            return
        fi

        local -a missing=()
        local mgr logical pkg inst
        while IFS=$'\t' read -r mgr logical pkg; do
            [[ -z "$mgr" ]] && continue
            inst=$(_get_installed_file "$mgr")
            grep -qxF "$pkg" "$inst" || missing+=("$logical ${BC_COLOR_BLUE}[$mgr:$pkg]${BC_COLOR_RESET}")
        done <<< "$resolved"

        if [[ ${#missing[@]} -gt 0 ]]; then
            echo -e "\n${BC_COLOR_YELLOW}  ⚠ Missing from ${BC_COLOR_BOLD}$label${BC_COLOR_RESET}${BC_COLOR_YELLOW}:${BC_COLOR_RESET}"
            local m
            for m in "${missing[@]}"; do
                echo -e "${BC_COLOR_RED}    ✗ $m${BC_COLOR_RESET}"
            done
            any_missing=1
        else
            echo -e "${BC_COLOR_GREEN}  ✓ $label — all present${BC_COLOR_RESET}"
        fi
    }

    local file
    if [[ ${#args[@]} -eq 0 ]]; then
        while IFS= read -r file; do
            _check_one_file "$file"
        done < <(_pkg_active_files)
    else
        local arg
        for arg in "${args[@]}"; do
            file=$(_pkg_category_file "$arg")
            if [[ -z "$file" ]]; then
                echo -e "${BC_COLOR_YELLOW}  ⚠ Unknown category: $arg${BC_COLOR_RESET}"
                continue
            fi
            _check_one_file "$file"
        done
    fi

    # shellcheck disable=SC2086
    [[ -n "$cleanup" ]] && rm -f $cleanup

    echo ""
    if [[ $any_missing -eq 1 ]]; then
        echo -e "${BC_COLOR_YELLOW}  Run 'pkg_install' to install missing packages.${BC_COLOR_RESET}"
    else
        echo -e "${BC_COLOR_GREEN}  All listed packages are installed.${BC_COLOR_RESET}"
    fi
}

pkg_install() {
    _pkg_require_jq || return 1
    local -a args=("$@")

    local native; native=$(_pkg_native_manager)
    if [[ -z "$native" ]]; then
        echo -e "${BC_COLOR_YELLOW}  ⚠ No supported native package manager detected.${BC_COLOR_RESET}"
        return 1
    fi

    _install_one_file() {
        local file="$1"
        local label; label=$(basename "$file" .json)
        local resolved; resolved=$(_pkg_resolve_file "$file")
        [[ -z "$resolved" ]] && return

        # Group missing packages by installer.
        declare -A by_installer=()
        local mgr logical pkg tmp
        while IFS=$'\t' read -r mgr logical pkg; do
            [[ -z "$mgr" ]] && continue
            tmp=$(mktemp)
            "_pkg_installed_$mgr" > "$tmp" 2>/dev/null
            if ! grep -qxF "$pkg" "$tmp"; then
                by_installer[$mgr]+="$pkg "
            fi
            rm -f "$tmp"
        done <<< "$resolved"

        if [[ ${#by_installer[@]} -eq 0 ]]; then
            echo -e "${BC_COLOR_GREEN}  ✓ $label — nothing to install${BC_COLOR_RESET}"
            return
        fi

        for mgr in "${!by_installer[@]}"; do
            local -a pkgs=(${by_installer[$mgr]})
            echo -e "\n${BC_COLOR_BLUE}  ▶ Installing from $label via $mgr${BC_COLOR_RESET}"
            "_pkg_install_$mgr" "${pkgs[@]}"
        done
    }

    local file
    if [[ ${#args[@]} -eq 0 ]]; then
        while IFS= read -r file; do _install_one_file "$file"; done < <(_pkg_active_files)
    else
        local arg
        for arg in "${args[@]}"; do
            file=$(_pkg_category_file "$arg")
            if [[ -z "$file" ]]; then
                echo -e "${BC_COLOR_YELLOW}  ⚠ Unknown category: $arg${BC_COLOR_RESET}"
                continue
            fi
            _install_one_file "$file"
        done
    fi
}
