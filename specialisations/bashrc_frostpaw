#!/bin/bash
# ==============================================================================
# FROSTPAW SPECIALISATION
# ==============================================================================
# Arch Linux home workstation configuration.
# Provides:
#   - Tailscale VPN management
#   - Fastfetch configuration
#   - Mamba/micromamba compatibility
# ==============================================================================

# ------------------------------------------------------------------------------
# Tailscale VPN Management
# ------------------------------------------------------------------------------
alias tsdown='sudo tailscale down && echo "✅ Tailscale disconnected"'
# alias tsup='sudo tailscale up --accept-routes --accept-dns --ssh && echo "✅ Tailscale connected"'
# Allow passing additional arguments to tsup, such as --reset
tsup() {
  if sudo tailscale up --accept-routes --accept-dns --ssh "$@"; then
    echo "✅ Tailscale connected"
  else
    echo "❌ Tailscale failed to connect. Try: tsup --reset"
    return 1
  fi
}

# ------------------------------------------------------------------------------
# Fastfetch Configuration
# ------------------------------------------------------------------------------
# Not exporting FASTFETCH_BIN as the binary is already in the PATH
# Pick an ARM-friendly config on aarch64, otherwise use the default Frostpaw one.
if [ -z "${FASTFETCH_CONFIG:-}" ]; then
  if [ "$(uname -m)" = "aarch64" ]; then
    export FASTFETCH_CONFIG="$BASH_CONFIG_DIR/configs/fastfetch_spark.jsonc"
  else
    export FASTFETCH_CONFIG="$BASH_CONFIG_DIR/configs/fastfetch_frostpaw.jsonc"
  fi
fi

# ------------------------------------------------------------------------------
# Mamba Compatibility
# ------------------------------------------------------------------------------
# If mamba is not installed, alias to micromamba
if ! command -v mamba &>/dev/null; then
  alias mamba='micromamba'
fi
