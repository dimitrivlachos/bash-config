# ==============================================================================
# DIAMOND-SPECIFIC PROXY FUNCTIONS
# ==============================================================================

# Diamond SOCKS proxy functions (for accessing Diamond intranet from local machine)
# Start Diamond SOCKS proxy for web browsing (runs in background)
diamond-proxy() {
    local port="${1:-8080}"
    local pid_file="$HOME/.diamond-proxy.pid"

    # Check if already running
    if [[ -f "$pid_file" ]] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
        bc_log_warn "SOCKS proxy already running on port $port (PID: $(cat "$pid_file"))"
        return 0
    fi

    bc_log_info "Starting SOCKS proxy on port $port..."
    ssh -D "$port" -C -N -q bastion </dev/null >/dev/null 2>&1 & # Detach from terminal, run in background
    local proxy_pid=$!
    disown "$proxy_pid"
    echo "$proxy_pid" > "$pid_file"
    bc_log_success "SOCKS proxy running on port $port (PID: $proxy_pid)"
    echo "Configure FoxyProxy: SOCKS5 127.0.0.1:$port — patterns: *.diamond.ac.uk, *.diamond"
    echo "Run 'ssh-exit' or 'diamond-proxy-stop' to stop"
}

# Stop the background SOCKS proxy
diamond-proxy-stop() {
    local pid_file="$HOME/.diamond-proxy.pid"
    if [[ -f "$pid_file" ]]; then
        local pid
        pid=$(cat "$pid_file")
        if kill "$pid" 2>/dev/null; then
            bc_log_success "SOCKS proxy stopped (PID: $pid)"
        else
            bc_log_debug "Proxy process already gone (PID: $pid)"
        fi
        rm -f "$pid_file"
    else
        bc_log_debug "No SOCKS proxy PID file found"
    fi
}

# List all active Diamond SSH connections
diamond-proxy-list() {
    bc_log_info "Active Diamond SSH connections:"
    pgrep -af "ssh.*diamond" 2>/dev/null || echo "No active Diamond SSH connections found"
}

