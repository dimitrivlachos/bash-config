#!/bin/bash
# ==============================================================================
# SSH MANAGEMENT
# ==============================================================================
# Comprehensive SSH management for bash-config including:
#   - SSH config management (symlink to secrets)
#   - SSH agent management (key caching via one agent per machine)
#   - SSH key generation helper (per-machine keys, never stored in git)
#   - Master connection management (multiplexing via ControlMaster)
#   - Daily work setup helper
#   - Diamond SOCKS proxy support
#
# Agent design: the agent exists to CACHE UNLOCKED KEYS (so passphrases and
# YubiKey touches aren't needed on every operation); connection multiplexing
# is handled separately by ControlMaster in ssh_config. Exactly one agent per
# machine, by construction: a systemd user service with a fixed socket path
# where available, otherwise a per-host env-file agent that is reused or
# replaced (never accumulated). No per-shell EXIT traps; a shared agent must
# outlive the shell that started it.
#
# Quick Commands:
#   ssh-setup     - Full work day setup (config + agent + master connections)
#   ssh-status    - Show active master connections
#   ssh-help      - Detailed help for all SSH functions
#
# All functions are prefixed with bc_ for consistency.
# ==============================================================================

# ==============================================================================
# SSH CONFIG MANAGEMENT
# ==============================================================================

# Setup SSH config via symlink to secrets
bc_setup_ssh_config() {
    local ssh_dir="$HOME/.ssh"
    local config_file="$ssh_dir/config"
    local secrets_ssh_config="$BASH_CONFIG_DIR/secrets/ssh_config"
    local backup_suffix=".backup.$(date +%Y%m%d_%H%M%S)"
    
    bc_log_debug "Setting up SSH config: $config_file -> $secrets_ssh_config"
    
    # Ensure SSH directory exists
    mkdir -p "$ssh_dir"
    chmod 700 "$ssh_dir"
    bc_log_debug "SSH directory created/verified: $ssh_dir"
    
    # Check if secrets SSH config exists
    if [[ ! -f "$secrets_ssh_config" ]]; then
        bc_log_error "SSH config not found in secrets: $secrets_ssh_config"
        return 1
    fi
    bc_log_debug "Secrets SSH config found: $secrets_ssh_config"
    
    # Check if already correctly configured
    if bc_check_ssh_config silent >/dev/null 2>&1; then
        bc_log_info "SSH config already correctly configured"
        # Still ensure smart-proxy symlink exists even if config is already set up
        bc_setup_smart_proxy
        return 0
    fi
    
    # Handle existing config file
    if [[ -L "$config_file" ]]; then
        local current_target=$(readlink "$config_file")
        bc_log_info "Removing existing symlink (pointed to: $current_target)"
        rm "$config_file"
    elif [[ -f "$config_file" ]]; then
        mv "$config_file" "${config_file}${backup_suffix}"
        bc_log_info "Backed up existing SSH config to: ${config_file}${backup_suffix}"
    fi
    bc_log_debug "Handled existing config file"
    
    # Create symlink and set permissions
    ln -s "$secrets_ssh_config" "$config_file"
    chmod 600 "$secrets_ssh_config"
    bc_log_success "SSH config symlinked to secrets repository"

    # Also set up SK SSH key handles
    bc_setup_sk_ssh_handles

    # Symlink smart-proxy so ProxyCommands work from GUI apps (e.g. VS Code)
    # that launch ssh without the full shell environment ($BASH_CONFIG_DIR unset)
    bc_setup_smart_proxy
}

# Symlink ssh-smart-proxy.sh into ~/.ssh/smart-proxy so ssh_config can reference
# it via $HOME/.ssh/smart-proxy — available even from GUI apps (e.g. VS Code)
# that launch ssh without the full shell environment ($BASH_CONFIG_DIR unset)
bc_setup_smart_proxy() {
    local ssh_dir="$HOME/.ssh"
    local script="$BASH_CONFIG_DIR/scripts/ssh-smart-proxy.sh"
    local target="$ssh_dir/smart-proxy"

    if [[ ! -f "$script" ]]; then
        bc_log_debug "Smart proxy script not found: $script"
        return 0
    fi

    if [[ -L "$target" ]] && [[ "$(readlink "$target")" == "$script" ]]; then
        bc_log_debug "Smart proxy already linked: ~/.ssh/smart-proxy"
        return 0
    fi

    ln -sfn "$script" "$target"
    chmod 755 "$script"
    bc_log_success "Smart proxy symlinked: ~/.ssh/smart-proxy → scripts/ssh-smart-proxy.sh"
}

# Symlink YubiKey SK SSH key handles from secrets into ~/.ssh/
bc_setup_sk_ssh_handles() {
    local ssh_dir="$HOME/.ssh"
    local sk_dir="$BASH_CONFIG_DIR/secrets/sk_ssh_handles"

    if [[ ! -d "$sk_dir" ]]; then
        bc_log_debug "No SK SSH handles directory found: $sk_dir"
        return 0
    fi

    mkdir -p "$ssh_dir"
    chmod 700 "$ssh_dir"

    local linked=0
    local skipped=0
    for handle in "$sk_dir"/id_ed25519_sk_*; do
        [[ -f "$handle" ]] || continue
        local name
        name="$(basename "$handle")"
        local target="$ssh_dir/$name"

        if [[ -L "$target" ]] && [[ "$(readlink "$target")" == "$handle" ]]; then
            bc_log_debug "SK handle already linked: $name"
            ((skipped++))
            continue
        fi

        # Back up any existing non-symlink file
        if [[ -f "$target" && ! -L "$target" ]]; then
            mv "$target" "${target}.backup.$(date +%Y%m%d_%H%M%S)"
            bc_log_info "Backed up existing $name"
        fi

        ln -sfn "$handle" "$target"
        chmod 600 "$handle"
        bc_log_debug "Linked SK handle: $name"
        ((linked++))
    done

    if [[ $linked -gt 0 ]]; then
        bc_log_success "Linked $linked SK SSH key handle(s) into ~/.ssh/"
    elif [[ $skipped -gt 0 ]]; then
        bc_log_info "All $skipped SK SSH key handle(s) already linked"
    else
        bc_log_debug "No SK SSH key handles found to link"
    fi
}

# SSH config validation helper
bc_check_ssh_config() {
    local silent="${1:-false}"
    local config_file="$HOME/.ssh/config"
    local secrets_ssh_config="$BASH_CONFIG_DIR/secrets/ssh_config"
    
    bc_log_debug "Checking SSH config: $config_file -> $secrets_ssh_config"
    
    if [[ ! -f "$secrets_ssh_config" ]]; then
        [[ "$silent" != "silent" ]] && bc_log_error "SSH config not found in secrets: $secrets_ssh_config"
        return 1
    fi
    
    if [[ ! -L "$config_file" ]]; then
        [[ "$silent" != "silent" ]] && bc_log_warn "SSH config is not a symlink to secrets"
        bc_log_debug "Config file is not a symlink: $config_file"
        return 1
    fi
    
    local target=$(readlink "$config_file")
    if [[ "$target" != "$secrets_ssh_config" ]]; then
        [[ "$silent" != "silent" ]] && bc_log_warn "SSH config symlink points to wrong location: $target"
        bc_log_debug "Symlink target mismatch: expected $secrets_ssh_config, got $target"
        return 1
    fi
    
    [[ "$silent" != "silent" ]] && bc_log_success "SSH config correctly symlinked to secrets"
    bc_log_debug "SSH config validation passed"
    return 0
}

# Fix SSH directory and file permissions to meet OpenSSH's strict requirements
bc_fix_ssh_permissions() {
    local ssh_dir="$HOME/.ssh"

    chmod 700 "$ssh_dir"                          # Only owner can read/write/enter
    chmod 600 "$ssh_dir"/config 2>/dev/null       # Only owner can read/write SSH config
    chmod 600 "$ssh_dir"/id_* 2>/dev/null         # Private keys: owner read/write only
    chmod 644 "$ssh_dir"/id_*.pub 2>/dev/null     # Public keys: owner read/write, others read
    chmod 600 "$ssh_dir"/authorized_keys 2>/dev/null  # Authorised keys: owner read/write only
    chmod 600 "$ssh_dir"/known_hosts 2>/dev/null  # Known hosts: owner read/write only

    # Also fix permissions on the secrets config (symlink target)
    if [[ -n "$BASH_CONFIG_DIR" && -f "$BASH_CONFIG_DIR/secrets/ssh_config" ]]; then
        chmod 600 "$BASH_CONFIG_DIR/secrets/ssh_config"  # Symlink target must also be 600
    fi

    bc_log_success "SSH permissions fixed"
}

# ==============================================================================
# MASTER CONNECTION MANAGEMENT
# ==============================================================================

# Simple master connection management
bc_ssh_master_start() {
    local host="$1"
    if [[ -z "$host" ]]; then
        bc_log_error "Usage: bc_ssh_master_start <hostname>"
        return 1
    fi
    
    bc_log_debug "Attempting to start master connection to: $host"
    bc_log_info "Starting master connection to $host..."
    if ssh -MNf -o LogLevel=ERROR "$host" </dev/null 2>/dev/null; then # Detach from terminal, run in background, suppress output
        bc_log_success "Master connection to $host started"
        return 0
    else
        bc_log_error "Failed to start master connection to $host"
        return 1
    fi
}

bc_ssh_master_status() {
    bc_log_debug "Checking for active SSH master connections in ~/.ssh/cm-*"
    bc_log_info "Active SSH master connections:"
    if ls ~/.ssh/cm-* 2>/dev/null | head -1 >/dev/null; then
        bc_log_debug "Found master connection control files"
        ls -la ~/.ssh/cm-* 2>/dev/null
    else
        bc_log_info "No active master connections found"
        bc_log_debug "No control files matching ~/.ssh/cm-* pattern"
    fi
}

bc_ssh_master_stop() {
    local stopped=0
    local failed=0
    bc_log_debug "Closing all SSH master connections via ControlPath sockets"
    for socket in ~/.ssh/cm-*; do
        [[ -S "$socket" ]] || continue
        local label
        label=$(basename "$socket")
        if ssh -O exit -o ControlPath="$socket" placeholder 2>/dev/null; then
            bc_log_success "Closed: $label"
            ((stopped++))
        else
            # Socket may already be dead — remove the stale file
            rm -f "$socket"
            bc_log_debug "Removed stale socket: $label"
            ((failed++))
        fi
    done
    if [[ $stopped -eq 0 && $failed -eq 0 ]]; then
        bc_log_info "No active master connections found"
    else
        [[ $stopped -gt 0 ]] && bc_log_success "Closed $stopped master connection(s)"
        [[ $failed -gt 0 ]] && bc_log_debug "Removed $failed stale socket(s)"
    fi

    # Also stop the SOCKS proxy if running
    diamond-proxy-stop
}

# ==============================================================================
# DAILY WORK SETUP
# ==============================================================================

# Daily work setup - main function for setting up SSH for work
bc_ssh_workday_setup() {
    local start_proxy="${1:-false}"
    local proxy_port="${2:-8080}"
    
    bc_log_info "🚀 Setting up SSH for work day..."
    echo
    
    # 1. Attach to the machine's SSH agent (starts one only if needed)
    bc_log_info "🔐 Attaching to SSH agent..."
    bc_ssh_agent_attach
    echo
    
    # 2. Validate/setup SSH config
    bc_log_info "📋 Checking SSH configuration..."
    if ! bc_check_ssh_config silent; then
        bc_log_info "Setting up SSH config..."
        bc_setup_ssh_config || return 1
    else
        bc_log_success "SSH config is ready"
    fi
    echo

    # 3. Ensure SK SSH key handles and smart-proxy are symlinked
    bc_log_info "🔑 Checking YubiKey SK key handles..."
    bc_setup_sk_ssh_handles
    bc_setup_smart_proxy
    echo
    
    # 4. Start master connection to bastion (optional — not reachable from inside Diamond)
    bc_log_info "🏢 Starting bastion master connection..."
    if ! bc_ssh_master_start bastion; then
        bc_log_warn "Could not reach bastion — skipping (normal when already on Diamond's internal network)"
    fi
    echo

    # 5. Show status
    bc_log_info "📊 Connection status:"
    bc_ssh_master_status
    echo

    bc_log_success "🎉 Work day SSH setup complete!"
    bc_log_info "💡 All SSH connections will now use the shared master connection"

    # 6. Optionally start Diamond proxy
    if [[ "$start_proxy" == "true" || "$start_proxy" == "proxy" ]]; then
        echo
        bc_log_info "🌐 Starting Diamond SOCKS proxy..."
        diamond-proxy "$proxy_port"
    fi
}

# ==============================================================================
# SSH AGENT MANAGEMENT
# ==============================================================================
# One agent per machine. Preference order in bc_ssh_agent_attach:
#   1. An already-working agent (inherited env or forwarded from another host)
#   2. The systemd user service socket (frostpaw/asteria, see
#      configs/systemd/user/ssh-agent.service, installed by
#      bc_setup_ssh_agent_service)
#   3. A per-host env-file agent (diamond, no systemd --user; the env file is
#      suffixed with the short hostname because the NFS home is shared across
#      bastion/workstation nodes)
# Keys are loaded lazily: ssh_config sets AddKeysToAgent yes, so the first use
# of a key caches it in the agent for every later operation.

# Check if a specific SSH key is loaded in the agent
bc_is_ssh_key_loaded() {
    local key_file="$1"
    if [[ -z "$key_file" || ! -f "$key_file" ]]; then
        bc_log_debug "Invalid key file provided: $key_file"
        return 1
    fi

    bc_log_debug "Checking if SSH key is loaded: $key_file"
    local key_fingerprint
    key_fingerprint=$(ssh-keygen -lf "$key_file" 2>/dev/null | awk '{print $2}')
    bc_log_debug "Key fingerprint: $key_fingerprint"

    if [[ -n "$key_fingerprint" ]] && ssh-add -l 2>/dev/null | grep -q "$key_fingerprint"; then
        bc_log_debug "Key is loaded in agent"
        return 0
    else
        bc_log_debug "Key is not loaded in agent"
        return 1
    fi
}

# Attach this shell to the machine's single SSH agent (starting one only as a
# last resort). Idempotent and cheap, called at module load for interactive
# shells. ssh-add exit codes: 0 = agent has keys, 1 = agent empty (both mean
# the agent is reachable), 2 = cannot connect.
bc_ssh_agent_attach() {
    # rc capture via '|| rc=$?' keeps this safe under 'set -e' callers
    # (ssh-add exits 1 for a reachable-but-empty agent, which is fine)
    local rc

    # 1. Inherited or forwarded agent already working? Keep it.
    if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        rc=0; ssh-add -l >/dev/null 2>&1 || rc=$?
        [[ $rc -le 1 ]] && return 0
        bc_log_debug "Inherited SSH_AUTH_SOCK is dead, discarding: $SSH_AUTH_SOCK"
        unset SSH_AUTH_SOCK SSH_AGENT_PID
    fi

    # 2. systemd user service socket (fixed path, singleton by construction)
    local sock="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/ssh-agent.socket"
    if [[ -S "$sock" ]]; then
        export SSH_AUTH_SOCK="$sock"
        bc_log_debug "Attached to systemd ssh-agent socket: $sock"
        return 0
    fi

    # 3. File-based fallback for hosts without systemd --user (diamond).
    #    Per-host env file: the NFS home is shared across bastion/ws nodes.
    #    $HOSTNAME rather than hostname(1), which isn't installed everywhere.
    local shorthost="${HOSTNAME:-$(uname -n)}"
    local envf="$HOME/.ssh/agent-env.${shorthost%%.*}"
    if [[ -f "$envf" ]]; then
        # shellcheck source=/dev/null
        source "$envf" >/dev/null
        rc=0; ssh-add -l >/dev/null 2>&1 || rc=$?
        [[ $rc -le 1 ]] && return 0
        # Stale entry: kill any orphaned agent process before replacing it,
        # so dead agents never accumulate.
        bc_log_debug "Env-file agent is dead, replacing (PID: ${SSH_AGENT_PID:-none})"
        [[ -n "${SSH_AGENT_PID:-}" ]] && kill "$SSH_AGENT_PID" 2>/dev/null
    fi
    (umask 077; ssh-agent -s > "$envf")
    # shellcheck source=/dev/null
    source "$envf" >/dev/null
    bc_log_debug "Started new agent for ${shorthost%%.*} (PID: ${SSH_AGENT_PID:-?})"
}

# Install/enable the systemd --user unit that owns the machine's ssh-agent.
# Mirrors bc_setup_atuin_daemon: symlink the repo unit, enable, verify.
bc_setup_ssh_agent_service() {
    local src="${BASH_CONFIG_DIR:-}/configs/systemd/user/ssh-agent.service"
    local dest_dir="$HOME/.config/systemd/user"

    if ! command -v systemctl >/dev/null 2>&1; then
        bc_log_error "systemctl not found, this host does not use systemd"
        bc_log_info "bc_ssh_agent_attach will use the env-file fallback instead"
        return 1
    fi
    if [[ ! -f "$src" ]]; then
        bc_log_error "Unit file not found: $src"
        return 1
    fi

    mkdir -p "$dest_dir"
    ln -sf "$src" "$dest_dir/ssh-agent.service"
    systemctl --user daemon-reload
    systemctl --user enable --now ssh-agent.service >/dev/null 2>&1

    if [[ "$(systemctl --user is-active ssh-agent.service 2>/dev/null)" == "active" ]]; then
        bc_log_success "ssh-agent.service active (socket: ${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/ssh-agent.socket)"
        bc_log_info "New shells attach automatically; run bc_ssh_agent_attach in existing ones"
    else
        bc_log_error "ssh-agent.service failed to start"
        bc_log_info "Inspect: systemctl --user status ssh-agent.service"
        return 1
    fi
}

# Kill any user-owned ssh-agent processes that are NOT the managed one
# (the systemd service or the current env-file agent). Visibility + manual
# safety valve against agent pileup.
bc_ssh_agent_prune() {
    local -a agents=()
    mapfile -t agents < <(pgrep -u "$USER" -x ssh-agent 2>/dev/null)
    if [[ ${#agents[@]} -eq 0 ]]; then
        bc_log_info "No ssh-agent processes running"
        return 0
    fi

    # The systemd-managed agent's PID (if the service is running)
    local systemd_pid=""
    if command -v systemctl >/dev/null 2>&1; then
        systemd_pid=$(systemctl --user show ssh-agent.service -p MainPID --value 2>/dev/null)
    fi

    # Counters use var=$((var+1)) rather than ((var++)), which returns
    # status 1 at zero and would abort 'set -e' callers
    local killed=0 kept=0
    local pid
    for pid in "${agents[@]}"; do
        if [[ -n "$systemd_pid" && "$pid" == "$systemd_pid" ]]; then
            bc_log_debug "Keeping systemd agent (PID: $pid)"
            kept=$((kept+1))
            continue
        fi
        if [[ -n "${SSH_AGENT_PID:-}" && "$pid" == "$SSH_AGENT_PID" ]]; then
            bc_log_debug "Keeping current session's env-file agent (PID: $pid)"
            kept=$((kept+1))
            continue
        fi
        if kill "$pid" 2>/dev/null; then
            bc_log_debug "Killed stray ssh-agent (PID: $pid)"
            killed=$((killed+1))
        fi
    done

    if [[ $killed -gt 0 ]]; then
        bc_log_success "Pruned $killed stray ssh-agent process(es), kept $kept"
    else
        bc_log_info "No stray agents to prune ($kept managed agent(s) running)"
    fi
}

# Show the machine's agent state: source, socket, loaded keys, process count
bc_ssh_agent_status() {
    bc_log_info "SSH Agent Status"

    local -a agents=()
    mapfile -t agents < <(pgrep -u "$USER" -x ssh-agent 2>/dev/null)
    echo -e "  ${BC_COLOR_BLUE}ssh-agent processes for $USER: ${#agents[@]}${BC_COLOR_RESET}"
    if [[ ${#agents[@]} -gt 1 ]]; then
        echo -e "  ${BC_COLOR_YELLOW}More than one agent running, consider bc_ssh_agent_prune${BC_COLOR_RESET}"
    fi

    if [[ -z "${SSH_AUTH_SOCK:-}" ]]; then
        echo -e "  ${BC_COLOR_RED}This shell has no agent (SSH_AUTH_SOCK unset), run bc_ssh_agent_attach${BC_COLOR_RESET}"
        return 1
    fi

    local source_desc="inherited/forwarded"
    local systemd_sock="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/ssh-agent.socket"
    if [[ "$SSH_AUTH_SOCK" == "$systemd_sock" ]]; then
        source_desc="systemd user service"
    elif [[ -n "${SSH_AGENT_PID:-}" ]]; then
        source_desc="env-file agent (PID: $SSH_AGENT_PID)"
    fi
    echo -e "  ${BC_COLOR_GREEN}Socket: $SSH_AUTH_SOCK ($source_desc)${BC_COLOR_RESET}"

    local keys rc=0
    keys=$(ssh-add -l 2>/dev/null) || rc=$?
    case $rc in
        0)
            echo -e "  ${BC_COLOR_GREEN}Loaded keys:${BC_COLOR_RESET}"
            echo "$keys" | sed 's/^/    /'
            ;;
        1)
            echo -e "  ${BC_COLOR_YELLOW}Agent reachable, no keys loaded yet${BC_COLOR_RESET}"
            echo -e "  ${BC_COLOR_GRAY}Keys load automatically on first use (AddKeysToAgent yes)${BC_COLOR_RESET}"
            ;;
        *)
            echo -e "  ${BC_COLOR_RED}Cannot reach agent at $SSH_AUTH_SOCK, run bc_ssh_agent_attach${BC_COLOR_RESET}"
            return 1
            ;;
    esac
}

# ==============================================================================
# SSH KEY GENERATION
# ==============================================================================

# Generate the per-machine private keys this specialisation is expected to
# have, under the filenames ssh_config already probes for (Match exec test -f).
# Private keys are per-machine and NEVER stored in git; only public keys
# leave the machine. Interactive: ssh-keygen prompts for a passphrase, which
# the agent then caches (AddKeysToAgent yes) so it's needed once per boot.
bc_setup_ssh_keys() {
    local host="${HOSTNAME:-$(uname -n)}"
    host="${host%%.*}"
    # key name → description shown when offering to generate it
    local -a expected=()
    case "${BASH_SPECIALISATION:-}" in
        frostpaw)
            expected=(
                "id_ed25519_github_d:GitHub main account (dimitrivlachos)"
                "id_ed25519_github_s:GitHub second account"
                "id_ed25519_personal:personal hosts (asteria/acrux/lyra/polaris/spark/atlas)"
            )
            ;;
        asteria)
            expected=(
                "id_ed25519_github_d:GitHub main account (dimitrivlachos)"
                "id_ed25519_personal:personal hosts (acrux/lyra/polaris/spark/atlas)"
            )
            ;;
        diamond)
            expected=(
                "id_ed25519_github_d:GitHub main account (dimitrivlachos)"
            )
            ;;
        *)
            bc_log_warn "Unknown specialisation '${BASH_SPECIALISATION:-}', no key list defined"
            return 1
            ;;
    esac

    local entry key desc keyfile generated=0
    local -a new_keys=()
    for entry in "${expected[@]}"; do
        key="${entry%%:*}"
        desc="${entry#*:}"
        keyfile="$HOME/.ssh/$key"
        if [[ -f "$keyfile" ]]; then
            bc_log_debug "Key already exists: $key"
            continue
        fi
        echo
        bc_log_info "Missing key: $key ($desc)"
        local reply=""
        read -rp "  Generate it now? (y/N): " reply </dev/tty || return 0
        [[ "$reply" =~ ^[Yy]$ ]] || continue
        # Passphrase prompt comes from ssh-keygen itself; agent caches it later
        if ssh-keygen -t ed25519 -f "$keyfile" -C "$host-${key#id_ed25519_}-$(date +%Y%m)"; then
            new_keys+=("$key")
            generated=$((generated+1))
        else
            bc_log_error "ssh-keygen failed for $key"
        fi
    done

    if [[ $generated -eq 0 ]]; then
        echo
        bc_log_success "All expected keys for '${BASH_SPECIALISATION:-}' are present"
        return 0
    fi

    echo
    bc_log_success "Generated $generated key(s). Public keys to deploy:"
    for key in "${new_keys[@]}"; do
        echo
        case "$key" in
            id_ed25519_github_d)
                echo -e "  ${BC_COLOR_CYAN}$key.pub → GitHub main account: Settings → SSH and GPG keys${BC_COLOR_RESET}" ;;
            id_ed25519_github_s)
                echo -e "  ${BC_COLOR_CYAN}$key.pub → GitHub second account: Settings → SSH and GPG keys${BC_COLOR_RESET}" ;;
            id_ed25519_personal)
                echo -e "  ${BC_COLOR_CYAN}$key.pub → each personal host: ssh-copy-id -i ~/.ssh/$key.pub <host>${BC_COLOR_RESET}" ;;
            *)
                echo -e "  ${BC_COLOR_CYAN}$key.pub → deploy to the matching host's authorized_keys${BC_COLOR_RESET}" ;;
        esac
        cat "$HOME/.ssh/$key.pub" | sed 's/^/    /'
    done
}

