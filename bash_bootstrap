#!/bin/bash
# ==============================================================================
# ARCH LINUX BOOTSTRAP UTILITY
# ==============================================================================
# Automated setup for fresh Arch Linux installations.
# Installs packages in configurable tiers so you can tailor each machine.
#
# Usage:
#   bc_bootstrap                    # Interactive mode - choose tiers
#   bc_bootstrap --tier base        # Install only base tier
#   bc_bootstrap --tier all         # Install everything
#   bc_bootstrap --dry-run          # Show what would be installed
#   bc_bootstrap --list             # List all tiers and packages
#
# Package tiers:
#   base        - Essential system packages (always recommended)
#   desktop-kde - KDE Plasma desktop environment
#   desktop-hyprland - Hyprland wayland compositor
#   audio       - PipeWire audio stack
#   networking  - WiFi, Bluetooth, SSH, VPN
#   dev         - Development tools and editors
#   media       - Media players, browsers, chat apps
#   gaming      - Steam, Moonlight
#   hardware    - NVIDIA drivers, Intel microcode, TLP
#   utilities   - System monitoring, file tools, misc
#   fonts       - Nerd Fonts and Liberation
#
# Flatpak is used for proprietary/Electron apps (Discord, Obsidian, Telegram, Zoom).
# Prefer paru over yay as AUR helper (same syntax, reviews PKGBUILDs by default).
#
# AUR and Flatpak packages are handled separately after pacman.
# ==============================================================================

# ==============================================================================
# PACKAGE TIER DEFINITIONS
# ==============================================================================
# Each tier is a bash array. Edit these to match your preferences.
# Packages sourced from work machine export as a baseline.

